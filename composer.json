{
    "name": "fof/masquerade",
    "description": "User profile builder extension for your Flarum forum.",
    "keywords": [
        "extension",
        "flarum",
        "user profile",
        "member profile",
        "profile"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniël Klabbers",
            "email": "daniel@klabbers.email",
            "homepage": "https://luceos.com/"
        },
        {
            "name": "Clark Winkelmann",
            "email": "clark.winkelmann@gmail.com",
            "homepage": "https://clarkwinkelmann.com/"
        }
    ],
    "support": {
        "issues": "https://github.com/FriendsOfFlarum/masquerade/issues",
        "source": "https://github.com/FriendsOfFlarum/masquerade",
        "forum": "https://discuss.flarum.org/d/5791"
    },
    "require": {
        "php": "^8.3",
        "flarum/core": "^v2.0.0-beta.8"
    },
    "replace": {
        "flagrow/masquerade": "*"
    },
    "extra": {
        "flarum-extension": {
            "title": "FoF Masquerade",
            "category": "feature",
            "icon": {
                "image": "resources/logo.svg",
                "backgroundColor": "#e74c3c",
                "backgroundSize": "90%",
                "backgroundRepeat": "no-repeat",
                "backgroundPosition": "center"
            },
            "optional-dependencies": [
                "flarum/gdpr"
            ]
        },
        "flagrow": {
            "discuss": "https://discuss.flarum.org/d/5791"
        },
        "flarum-cli": {
            "modules": {
                "githubActions": true
            }
        }
    },
    "autoload": {
        "psr-4": {
            "FoF\\Masquerade\\": "src/"
        }
    },
    "require-dev": {
        "flarum/phpstan": "^2.0.0-beta",
        "flarum/gdpr": "*"
    },
    "scripts": {
        "analyse:phpstan": "phpstan analyse",
        "clear-cache:phpstan": "phpstan clear-result-cache"
    },
    "scripts-descriptions": {
        "analyse:phpstan": "Run static analysis"
    }
}
